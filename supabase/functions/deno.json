{
  "imports": {
    "@supabase/supabase-js": "jsr:@supabase/supabase-js@^2.49.0",
    "std/": "https://deno.land/std@0.224.0/"
  },
  "tasks": {
    "test": "deno test --allow-env --allow-net=api.telegram.org",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check telegram-webhook/index.ts telegram-webhook/handlers.ts _shared/*.ts _shared/tools/*.ts _shared/tools/common/*.ts tests/*.ts"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  }
}
